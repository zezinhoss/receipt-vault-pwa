{
  "name": "Receipt Vault",
  "short_name": "Vault",
  "start_url": "./index.html",
  "display": "standalone",
  "background_color": "#0a0a0a",
  "theme_color": "#facc15",
  "icons": [
    {
      "src": "./icon.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "share_target": {
    "action": "./index.html?shared_file=1",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "receipt_file",
          "accept": ["application/pdf", "image/*"]
        }
      ]
    }
  }
}
